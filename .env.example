# ============================================================
# Halal Directory — Required Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ----- Cloudflare (GitHub Actions secrets) ----------------
# API token with Pages:Edit + D1:Edit permissions
CLOUDFLARE_API_TOKEN=

# Your Cloudflare account ID (visible in dash URL)
CLOUDFLARE_ACCOUNT_ID=

# ----- Cloudflare D1 (set via `wrangler secret put` or dashboard) -
# D1 database UUID — shown after `wrangler d1 create halal-directory`
D1_DATABASE_ID=

# ----- Cloudinary (set as Wrangler secrets) ---------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- Admin auth (set as Wrangler secret) ----------------
# Random 64-char hex string — used to sign session tokens
ADMIN_SESSION_SECRET=

# ----- Build-time public vars (GitHub Actions secret) -----
# Full URL of the deployed API Worker, e.g. https://api.halal.nusba.com
PUBLIC_WORKER_URL=https://api.halal.nusba.com

# ----- Local dev only -------------------------------------
# Leave blank for local Wrangler dev (uses local D1 emulation)
# LOCAL_D1_PATH=.wrangler/state/v3/d1
