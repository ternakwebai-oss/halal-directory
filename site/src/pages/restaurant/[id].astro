---
import { env } from 'cloudflare:workers';

const { id } = Astro.params as { id: string };

// Only handle purely numeric IDs; anything else is a 404
if (!/^\d+$/.test(id)) {
  return Astro.redirect('/404', 404);
}

const db = env.DB as D1Database;

if (db) {
  const found = await db.prepare(`
    SELECT slug FROM places WHERE id = ? AND published = 1 LIMIT 1
  `).bind(Number(id)).first<{ slug: string }>();

  if (found) {
    return Astro.redirect('/places/' + found.slug, 301);
  }
}

return Astro.redirect('/404', 404);
---
